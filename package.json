{
  "name": "sidra",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "package:macos": "pnpm build && node tools/distributable/create-macos-zip.mjs",
    "test": "pnpm -r test && pnpm test:native-hosts && pnpm test:distributable",
    "test:native-hosts": "node --test tools/native-hosts/*.test.mjs",
    "test:distributable": "node --test tools/distributable/*.test.mjs",
    "test:e2e": "pnpm --filter @sidra/extension test:e2e",
    "check": "pnpm -r check"
  },
  "devDependencies": {
    "@types/node": "^20.19.25",
    "@vitejs/plugin-react": "^5.1.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^4.0.15"
  },
  "packageManager": "pnpm@10.30.1+sha512.3590e550d5384caa39bd5c7c739f72270234b2f6059e13018f975c313b1eb9fefcc09714048765d4d9efe961382c312e624572c0420762bdc5d5940cdf9be73a"
}
