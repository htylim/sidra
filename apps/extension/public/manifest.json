{
  "manifest_version": 3,
  "name": "Sidra",
  "version": "0.0.0",
  "minimum_chrome_version": "114",
  "description": "Chat with a local AI agent about the current page.",
  "key": "",
  "permissions": ["sidePanel", "nativeMessaging", "storage", "tabs", "scripting"],
  "host_permissions": ["<all_urls>"],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "Sidra"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
