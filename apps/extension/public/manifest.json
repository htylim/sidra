{
  "manifest_version": 3,
  "name": "Sidra",
  "version": "0.0.0",
  "description": "Chat with a local AI agent about the current page.",
  "permissions": ["sidePanel", "nativeMessaging", "storage", "tabs", "scripting"],
  "host_permissions": ["<all_urls>"],
  "side_panel": {
    "default_path": "side-panel.html"
  },
  "action": {
    "default_title": "Sidra"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
